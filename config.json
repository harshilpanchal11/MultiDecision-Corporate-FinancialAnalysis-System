{
  "scenarios": {
    "downside": "Downside",
    "base": "Base Case",
    "upside": "Upside"
  },
  "scenarioCount": 3,
  "defaultDecisionType": "acquisition_vs_organic",
  "requiredMetricsList": [
    "NPV",
    "IRR",
    "Payback Period",
    "Cumulative FCF",
    "ROI",
