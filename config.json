  "sensitivityRanges": {
    "revenue": [-30, 30],
    "costs": [-30, 30],
    "growth_rate": [-30, 30],
    "discount_rate": [-20, 20],
    "churn_rate": [-30, 30]
  },
  "modelId": "gpt-4o",
  "temperature": 0.3,
  "maxTokens": 4096,
  "maxRetries": 2,
  "tableValidation": true,
  "outputFilenamePattern": "{businessProblem}_{timestamp}.md",
  "outputDirectory": "./outputs"
}
